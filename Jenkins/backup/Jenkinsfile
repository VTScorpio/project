    //                 kubectl rollout status deployment/backup-deployment

    //                 echo "[INFO] Verificare poduri active..."
    //                 kubectl get pods -o wide
    //                 '''
    //             } else {
    //                 error("[ERROR] Imaginile Docker pentru backup sau monitor lipsesc. Oprește pipeline-ul.")
    //             }
