    //             if (backupExists != "0" && monitorExists != "0") {
    //                 sh '''
    //                 echo "[INFO] Setăm contextul Minikube..."
    //                 kubectl config use-context minikube

    //                 echo "[INFO] Aplicăm fișierele YAML pentru backup și monitor..."
